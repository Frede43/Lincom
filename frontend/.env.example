# Configuration Community Laboratory Burundi

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_MEDIA_URL=http://localhost:8000/media

# API Type Configuration
VITE_USE_DJANGO_API=true
VITE_MOCK_API=false

# Environment
VITE_NODE_ENV=development
VITE_APP_VERSION=1.0.0

# Features Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=true

# External Services
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=
VITE_STRIPE_PUBLIC_KEY=

# Security
VITE_CSP_ENABLED=true
VITE_RATE_LIMIT_ENABLED=true

# Development
VITE_DEBUG_MODE=true
VITE_MOCK_API=false

# Internationalization
VITE_DEFAULT_LANGUAGE=fr
VITE_SUPPORTED_LANGUAGES=fr,en,rn

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Social Login
VITE_GOOGLE_CLIENT_ID=
VITE_LINKEDIN_CLIENT_ID=

# Map Configuration (pour la localisation)
VITE_MAPBOX_TOKEN=

# Email Configuration (pour contact)
VITE_CONTACT_EMAIL=contact@comlab.bi
VITE_SUPPORT_EMAIL=support@comlab.bi

# Organization Info
VITE_ORG_NAME=Community Laboratory Burundi
VITE_ORG_ADDRESS=Avenue de l'Université, Bujumbura, Burundi
VITE_ORG_PHONE=+257 22 22 22 22
